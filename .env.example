# ─────────────────────────────────────────────
# Configurações gerais
# ─────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production

# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

DEBUG=False

# Separados por vírgula. Ex.: nicia-track.onrender.com,www.nicia-track.com
ALLOWED_HOSTS=nicia-track.onrender.com

# ─────────────────────────────────────────────
# Banco de dados (PostgreSQL)
# ─────────────────────────────────────────────
PGDATABASE=nicia_track
PGUSER=nicia_track
PGPASSWORD=your-db-password-here
PGHOST=localhost
PGPORT=5432

# ─────────────────────────────────────────────
# Segurança HTTPS (obrigatório em produção)
# ─────────────────────────────────────────────
# Separados por vírgula. Deve incluir HTTPS.
CSRF_TRUSTED_ORIGINS=https://nicia-track.onrender.com
